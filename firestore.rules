rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed() {
      return request.auth != null &&
        request.auth.token.email in [
          'ray@redacted.invalid',
          'aproo@redacted.invalid'
        ];
    }

    match /users/{userId} {
      allow read, write: if isAllowed();
    }

    match /couples/{coupleId}/{document=**} {
      allow read, write: if isAllowed();
    }

    match /pokes/{pokeId} {
      allow read, write: if isAllowed();
    }

    // Collection-group query support: the backup pipeline fetches comments
    // across every todo in one query (collectionGroup('comments')) rather
    // than enumerating todo IDs first. A nested match under
    // couples/{coupleId}/{document=**} authorizes path-anchored queries
    // fine, but Firestore requires a rule declared at this top level,
    // scoped to the collection ID directly, to authorize a collection-group
    // query against it.
    match /{path=**}/comments/{commentId} {
      allow read, write: if isAllowed();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
